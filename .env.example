# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Create a Service Account in Google Cloud Console and download JSON key
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ─── OpenAI (for SEO + Tags generation) ──────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Image Generation (e.g. Replicate / Stability AI / custom) ───────────────
REPLICATE_API_TOKEN=r8_your-replicate-token
# OR use Stability AI:
STABILITY_API_KEY=sk-your-stability-key

# ─── Security ─────────────────────────────────────────────────────────────────
API_SECRET=your-random-secret-string-here
